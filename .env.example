DISCORD_BOT_TOKEN=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.anthropic.com/v1
OPENAI_MODEL=claude-opus-4-6
DATABASE_PATH=./data/sushii-agent.db

# Per-guild JSON config
# emojiMap: maps custom emoji names to their unicode equivalents.
#           Keys tell the bot which custom emojis it can use; values are the unicode
#           equivalents it should render in responses (e.g. "blobheart" → ❤️).
GUILD_CONFIG='{
  "123456789012345678": {
    "allowedRoles": ["987654321098765432"],
    "allowedChannels": ["111222333444555666"],
    "emojiMap": {
      "blobheart": "❤️",
      "blobthumbsup": "👍",
      "blobsad": "😢"
    },
    "rules": "1. Be respectful. No harassment, slurs, threats, doxxing, or discrimination. Dismissive or hostile language (e.g. \"stfu\", \"shut up\") directed at someone is a Rule 1 violation.\n2. Keep it appropriate. No NSFW content, sexual remarks, or disturbing/shock content.\n3. No spam or disruption.\n4. Be authentic.\n5. Protect privacy.\n6. No advertising.\n7. English only.\n8. Respect mod decisions.\n9. Do not backseat moderate."
  }
}'
